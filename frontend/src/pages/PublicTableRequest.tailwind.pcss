@import url('https://fonts.googleapis.com/css2?family=Eagle+Lake&family=MedievalSharp&display=swap');

@tailwind utilities;

@keyframes flicker {
  0%, 100% { opacity: 0.2; }
  10% { opacity: 0.15; }
  20% { opacity: 0.25; }
  30% { opacity: 0.1; }
  40% { opacity: 0.2; }
  50% { opacity: 0.3; }
  60% { opacity: 0.15; }
  70% { opacity: 0.25; }
  80% { opacity: 0.1; }
  90% { opacity: 0.35; }
}

.animate-flicker {
  animation: flicker 4s ease-in-out infinite;
}

# API Base URL (optional)
# In development, use /api so requests go through Vite proxy.
VITE_API_URL=/api

# Dev proxy target for /api and /hubs
VITE_DEV_API_TARGET=http://127.0.0.1:5186

# Public app URL used to generate table QR links
# Set this to your LAN IP when testing with mobile, e.g. http://192.168.18.44:5173
VITE_PUBLIC_APP_URL=http://localhost:5173
